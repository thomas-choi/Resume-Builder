ANTHROPIC_API_KEY=sk-...
GITHUB_TOKEN=ghp-...            # optional: raises rate limits AND unlocks the
                                # GraphQL contribution data (contributed repos +
                                # per-repo commit counts). If it is the ingested
                                # user's OWN token it also unlocks their private
                                # org memberships + private repos; a token for
                                # anyone else never touches those endpoints.

# GitHub ingestion coverage (Phase 1.f / 1.g)
#GITHUB_INCLUDE_CONTRIBUTIONS=true   # false = owned + org repos only (no search/GraphQL)
#GITHUB_MAX_EXTERNAL_REPOS=15        # external repos kept, ranked by contribution volume
#GITHUB_INCLUDE_PRIVATE=true         # false = public repos only (memberships still found)
#GITHUB_MAX_CONTRIBUTION_PROBES=150  # budget for "did the user actually commit here?" checks
#GITHUB_MAX_ORG_REPOS=20             # org repos rendered; every org keeps at least one

# LLM provider (same method as FUND get_llm): anthropic | openai | google |
# nvidia | llamacpp | deepseek | openrouter. Defaults to anthropic.
# For llamacpp see OPERATIONS.md "Local LLM via llama.cpp" (server flags + sizing).
LLM_PROVIDER=anthropic
#LLM_API_KEY=                   # defaults to ANTHROPIC_API_KEY when unset
#LLM_TEMPERATURE=               # leave unset for Claude models (non-default sampling rejected)
#LLM_MAX_TOKENS=8000
#LLM_BASE_URL=                  # optional provider base URL override
#LLM_STREAM_TIMEOUT_S=90

# Per-stage model tiering (use ids valid for the selected LLM_PROVIDER)
EXTRACTION_MODEL=claude-haiku-4-5-20251001
SYNTHESIS_MODEL=claude-sonnet-5
TAILORING_MODEL=claude-sonnet-5
VALIDATION_MODEL=claude-sonnet-5
#COVER_LETTER_MODEL=            # defaults to TAILORING_MODEL
DATA_DIR=./data

# Document rendering (Phase 3). Rendered files land in data/documents/{tailor_id}/.
#DOCX_TEMPLATE=                 # optional base .docx supplying styles/letterhead
#RENDER_PDF=true                # false = .docx only (no LibreOffice call)
#LIBREOFFICE_BIN=soffice        # headless converter; shipped in the Docker image
#LIBREOFFICE_TIMEOUT_S=120

# Agent skills (SKILL.md per agent). Prompt content, not secrets — ships in the
# image. Unset/missing dir falls back to the inline prompt scaffolding.
SKILLS_DIR=./skills

# Logging
#LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR
#LOG_FILE=./logs/app.log        # unset = console only; rotates at 10MB, keeps 3 backups
