ANTHROPIC_API_KEY=sk-...
GITHUB_TOKEN=ghp-...            # optional FALLBACK: used only when a request
                                # supplies no `github_token` form field. Raises
                                # rate limits AND unlocks the GraphQL
                                # contribution data (contributed repos +
                                # per-repo commit counts). If it is the ingested
                                # user's OWN token it also unlocks their private
                                # org memberships + private repos; a token for
                                # anyone else never touches those endpoints.

# Server / networking — ONE source of truth for how the app is reached.
# PUBLIC_SCHEME + PUBLIC_HOST + API_PORT together derive PUBLIC_BASE_URL (magic-
# link base) and the default AUTH_ALLOWED_ORIGINS (CSRF gate), so moving a
# deployment usually means changing only these.
#PUBLIC_HOST=localhost          # hostname/IP the browser reaches the app at
#PUBLIC_SCHEME=http             # set https when served behind TLS
#API_PORT=8000                  # port uvicorn binds AND docker compose publishes.
                                # Cloud platforms that inject $PORT are honored:
                                # API_PORT wins, then $PORT, then 8000.
#UI_PORT=5173                   # dev-only: port the Vite dev server (npm run dev)
                                # listens on. No effect in prod (the API serves the
                                # built UI on API_PORT). When set, the UI is a
                                # SECOND origin — list both in AUTH_ALLOWED_ORIGINS.

# Docker: the container starts as root, then drops to the user that OWNS the
# mounted ./data dir (on the host, whoever ran `docker compose up`) so files it
# writes into ./data and ./logs are owned by you, not root — no config needed.
# Override that auto-detection only if the mount owner isn't the id you want:
#HOST_UID=1000
#HOST_GID=1000

# GitHub ingestion coverage (Phase 1.f / 1.g)
#GITHUB_INCLUDE_CONTRIBUTIONS=true   # false = owned + org repos only (no search/GraphQL)
#GITHUB_MAX_EXTERNAL_REPOS=15        # external repos kept, ranked by contribution volume
#GITHUB_INCLUDE_PRIVATE=true         # false = public repos only (memberships still found)
#GITHUB_MAX_CONTRIBUTION_PROBES=150  # budget for "did the user actually commit here?" checks
#GITHUB_MAX_ORG_REPOS=20             # org repos rendered; every org keeps at least one
#GITHUB_REPOS_PER_EXTRACTION=10      # repos per extraction call; lower = less truncation risk

# LLM provider (same method as FUND get_llm): anthropic | openai | google |
# nvidia | llamacpp | deepseek | openrouter. Defaults to anthropic.
# For llamacpp see OPERATIONS.md "Local LLM via llama.cpp" (server flags + sizing).
LLM_PROVIDER=anthropic
#LLM_API_KEY=                   # defaults to ANTHROPIC_API_KEY when unset
#LLM_TEMPERATURE=               # leave unset for Claude models (non-default sampling rejected)
#LLM_MAX_TOKENS=8000
#LLM_BASE_URL=                  # optional provider base URL override
#LLM_STREAM_TIMEOUT_S=90

# Per-stage model tiering (use ids valid for the selected LLM_PROVIDER)
EXTRACTION_MODEL=claude-haiku-4-5-20251001
SYNTHESIS_MODEL=claude-sonnet-5
TAILORING_MODEL=claude-sonnet-5
VALIDATION_MODEL=claude-sonnet-5
#COVER_LETTER_MODEL=            # defaults to TAILORING_MODEL
#REVIEW_MODEL=                  # defaults to VALIDATION_MODEL (it explains that gate)
DATA_DIR=./data

# Document rendering (Phase 3). Rendered files land in data/documents/{tailor_id}/.
#DOCX_TEMPLATE=                 # optional base .docx supplying styles/letterhead
#RENDER_PDF=true                # false = .docx only (no LibreOffice call)
#LIBREOFFICE_BIN=soffice        # headless converter; shipped in the Docker image
#LIBREOFFICE_TIMEOUT_S=120

# Human review (Phase 4). A flagged run pauses before rendering either way;
# these only control the explanatory brief the reviewer is shown.
#REVIEW_AGENT_ENABLED=true      # false = pause without the LLM-written brief
#REVIEW_MAX_TOOL_ITERATIONS=4   # bound on the agent's skill-loading tool loop

# Built review UI, served at "/". Absent → "/" redirects to /docs.
#FRONTEND_DIR=./frontend/dist

# Agent skills (SKILL.md per agent). Prompt content, not secrets — ships in the
# image. Unset/missing dir falls back to the inline prompt scaffolding.
SKILLS_DIR=./skills

# Accounts / passwordless auth (Phase 7).
# Mail delivery (7.a). `file` (default) drops a complete .eml into the outbox —
# open the newest file there to read the code (or click the link) with no SMTP.
# EMAIL_BACKEND=smtp             # file | console | smtp
#EMAIL_FROM=no-reply@localhost
#EMAIL_OUTBOX_DIR=./data/auth/outbox
#SMTP_HOST=                     # smtp backend only (Gmail: smtp.gmail.com — see OPERATIONS.md)
#SMTP_PORT=587                  # STARTTLS submission port (465/SSL not supported)
#SMTP_USER=                     # login only sent when set (Gmail: your full address)
#SMTP_PASSWORD=                 # Gmail requires a 16-char App Password, not your login password
#SMTP_STARTTLS=true
#SMTP_TIMEOUT_S=10
# Per-user isolation (7.c/7.d). AUTH_ENABLED=true (default) makes every business
# route require a session and roots data at data/users/{sha256(email)}/; =false
# runs legacy single-user mode under one synthetic account (no login).
#AUTH_ENABLED=true
#SINGLE_USER_EMAIL=local@example.com   # account used when AUTH_ENABLED=false
# Auth flow (7.b).
#AUTH_VERIFY_METHOD=code        # code (6-digit OTP) | link (magic link)
#VERIFY_CODE_LENGTH=6
#AUTH_MAX_CODE_ATTEMPTS=5       # wrong-code tries before a challenge is burned
# PUBLIC_BASE_URL and AUTH_ALLOWED_ORIGINS both DERIVE from PUBLIC_SCHEME+
# PUBLIC_HOST+API_PORT above — leave them unset for the common single-origin
# case (prod bundle is same-origin with the API). Set one only to override:
#PUBLIC_BASE_URL=https://resume.example.com   # magic-link base — never from Host header
#AUTH_ALLOWED_ORIGINS=http://localhost:8000,http://localhost:5173
                                # origins allowed to POST /auth/*; defaults to PUBLIC_BASE_URL.
                                # Set this ONLY when the UI loads from more than one origin —
                                # e.g. `npm run dev`, where the browser loads the Vite server
                                # (UI_PORT) and its proxy forwards that Origin unchanged, so the
                                # dev-server origin MUST be listed too or /auth/* returns 403.
#SESSION_COOKIE_NAME=rb_session
#SESSION_COOKIE_SECURE=true     # set false for local http
#SESSION_TTL_S=1209600          # 14 days, sliding
#SIGNUP_TTL_S=1800              # 30 min
#SIGNIN_TTL_S=900               # 15 min
#AUTH_MAX_SENDS_PER_HOUR=5      # challenges emailed per address

# Logging
LOG_LEVEL=DEBUG                 # DEBUG | INFO | WARNING | ERROR
LOG_FILE=./logs/app.log        # unset = console only; rotates at 10MB, keeps 3 backups
