# Production .env for the cloud VM — copy to `.env` in
# ~/projects/ResumeBuilder on the VM and fill in the secrets.
#
# This is deliberately NOT the full .env.example. It carries only (a) the
# secrets and (b) the handful of vars whose correct cloud value DIFFERS from the
# local default. Everything else keeps its default; consult .env.example when
# you need to tune ingestion budgets, model tiers or rendering.
#
# chmod 600 this file — it holds API keys and an SMTP password.

# ---- image to run (read by docker-compose.yml, not by the app) --------------
IMAGE_REPO=thomaschoi/resume-builder
IMAGE_TAG=latest                # pin to a git SHA to roll back: IMAGE_TAG=a1b2c3d

# ---- secrets ---------------------------------------------------------------
# With LLM_PROVIDER=deepseek (below) the key that matters is LLM_API_KEY.
# ANTHROPIC_API_KEY is only needed if you switch the provider back to anthropic.
LLM_API_KEY=sk-...              # DeepSeek platform key
#ANTHROPIC_API_KEY=sk-ant-...
#GITHUB_TOKEN=ghp-...           # optional fallback token (higher rate limits +
                                # richer contribution data). See OPERATIONS.md.

# ---- where the app is reached ----------------------------------------------
# THE THREE LINES BELOW ARE THE ONES THAT BREAK LOGIN IF WRONG.
# PUBLIC_HOST+PUBLIC_SCHEME+API_PORT derive PUBLIC_BASE_URL (the magic-link base)
# and the default AUTH_ALLOWED_ORIGINS (the CSRF gate on /auth/*). Leave
# PUBLIC_HOST at `localhost` and every sign-in POST from the browser is
# rejected with 403 bad origin.
PUBLIC_HOST=143.198.153.31
PUBLIC_SCHEME=http              # -> https the day a TLS proxy/domain goes in front
API_PORT=8000                   # port uvicorn binds AND compose publishes

# Serving over plain http:// on a bare IP means the browser DISCARDS a `Secure`
# cookie — the login would succeed and then every subsequent request would 401
# and bounce back to the verify screen. Flip to true together with
# PUBLIC_SCHEME=https, never before.
SESSION_COOKIE_SECURE=false

# ---- auth / mail -----------------------------------------------------------
AUTH_ENABLED=true               # per-user isolation; data/users/{sha256(email)}/
AUTH_VERIFY_METHOD=code         # 6-digit OTP; `link` needs mail that renders links

# The default `file` backend writes the verification email to
# data/auth/outbox/ INSIDE the VM — nobody signing up can read it, so real
# users cannot log in. Configure smtp before letting anyone else on.
EMAIL_BACKEND=smtp
EMAIL_FROM=no-reply@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587                   # STARTTLS submission (465/SSL unsupported)
SMTP_USER=you@gmail.com
SMTP_PASSWORD=                  # Gmail: a 16-char App Password, NOT the login password
SMTP_STARTTLS=true

# ---- models ----------------------------------------------------------------
# Mirrors the working local .env. langchain-deepseek ships in requirements.txt,
# so the image supports this provider with no rebuild change. The factory
# disables DeepSeek's thinking mode per request — thinking models reject the
# forced tool call that structured output depends on.
LLM_PROVIDER=deepseek
EXTRACTION_MODEL=deepseek-v4-flash
SYNTHESIS_MODEL=deepseek-v4-flash
TAILORING_MODEL=deepseek-v4-flash
VALIDATION_MODEL=deepseek-v4-flash
COVER_LETTER_MODEL=deepseek-v4-flash
REVIEW_MODEL=deepseek-v4-flash
LLM_MAX_TOKENS=16384
LLM_STREAM_TIMEOUT_S=300        # non-Anthropic providers can be slow on 8k+ outputs
LLM_TEMPERATURE=0.9             # parity with the local .env. OPERATIONS.md
                                # suggests ~0.2 for non-Claude providers: the
                                # extraction and validation stages are what the
                                # anti-fabrication gate rests on, and they want
                                # determinism more than variety. Lower it here
                                # first if you see invented claims in production.

# ---- storage / logging -----------------------------------------------------
# Both are container paths and match the volumes in docker-compose.yml.
DATA_DIR=/app/data
SKILLS_DIR=./skills
LOG_LEVEL=INFO                  # DEBUG is very chatty for an always-on server
LOG_FILE=./logs/app.log         # -> /app/logs/app.log -> ./logs/app.log on the host
